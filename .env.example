# Copy to .env and fill in real values. Never commit .env.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Shared secret clients must send in the X-MCP-Secret header.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_SHARED_SECRET=generate-a-long-random-string
# Optional: separate HTTP-referrer-restricted key for embedded-map URLs (these
# expose their key client-side). Falls back to GOOGLE_MAPS_API_KEY when unset.
# MAPS_EMBED_API_KEY=your-referrer-restricted-key
